class Solution {
    public List<Integer> findDisappearedNumbers(int[] nums) {
        int len=nums.length;
        for(int i=0;i<len;i++){
            int index=Math.abs(nums[i])-1;
            if(nums[index]>0){
                nums[index]=-nums[index];
            }
        }
        List<Integer>res=new ArrayList<>();
        for(int i=0;i<len;i++){
            if(nums[i]>0){
                res.add(i+1);
            }
        }
        return res;
    }
}
