class Solution {
    public boolean isMonotonic(int[] nums) {
        int n=nums.length;
        boolean flag=true;
        boolean flag1=true;
        for(int i=0;i<n;i++){
            for(int j=i+1;j<n;j++){
                if(nums[i]>nums[j]){
                    flag=false;
                }if(nums[i]<nums[j]){
                    flag1=false;
                }
            }
        }
        return flag||flag1;
    }
}
