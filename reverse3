class Solution {
    public String reverseWords(String s) {
        String token[]=s.split(" ");
        String result="";
        int n=s.length();
        for(int i=0;i< token.length;i++){
           String word=token[i];
            String rev="";
            for(int j=word.length()-1;j>=0;j--){
                rev +=word.charAt(j);
            }
            result+=rev;
            if(i!=token.length-1){
                result+=" ";
        }
        }
    return result;
    }

}
