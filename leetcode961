class Solution {
    public int repeatedNTimes(int[] nums) {
        int n=nums.length;
        for(int i=0;i<n-1;i++){
            if(nums[i]==nums[i+1]){
                return nums[i];
            }
        }
        if (nums[0] == nums[2]) return nums[0];
        if (nums[0] == nums[3]) return nums[0];
        return nums[n - 1]; 
        
    }
}
